[run]
branch = True
parallel = True
# Files explicitly under test. Add new files here when their test coverage
# reaches >= 95%. Files outside this list are excluded via `omit` below
# until they are migrated to the shared harness (plan.md 1.1.10 + per-cluster
# follow-ups).
source =
    hooks
    scripts
omit =
    # Hooks with tests but the hook body is hard to exercise from pytest
    # (requires git fixtures, large pattern catalogs, or runs only in
    # Stop-hook context). Tests in tests/hooks/<name>/ still run and guard
    # against regressions; they just don't push the total coverage above
    # 95% for these specific files.
    hooks/dangerous-command-blocker.py
    hooks/git-author-guard.py
    hooks/retro-pointer.py
    hooks/secret-scanner.py
    hooks/settings-hygiene.py
    # Scripts not yet under test.
    scripts/mutation_source_map.py
    scripts/mutation_ts_project_service.py
    scripts/context-monitor.py
    scripts/stale-memory-detector.py
    scripts/validate-agents.py
    scripts/validate-checklist-counts.py
    scripts/validate-counts.py
    scripts/validate-cross-refs.py
    scripts/validate-patterns.py
    scripts/validate-settings.py
    scripts/validate-skills.py
disable_warnings = include-ignored

[report]
fail_under = 95
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:

[paths]
source =
    .
