{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Bash",
      "NotebookEdit",
      "Read(/tmp/**)",
      "Read(/private/tmp/**)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(pnpm run *)",
      "Bash(pnpm exec *)",
      "Bash(npm run *)",
      "Bash(npx *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.development)",
      "Read(./.env.staging)",
      "Read(./.env.testing)",
      "Read(./.env.ci)",
      "Read(./.env.docker)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.production)",
      "Write(./.env.development)",
      "Write(./.env.staging)",
      "Write(./.env.testing)",
      "Write(./.env.ci)",
      "Write(./.env.docker)",
      "Write(./secrets/**)",
      "Write(./config/credentials.json)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.production)",
      "Edit(./.env.development)",
      "Edit(./.env.staging)",
      "Edit(./.env.testing)",
      "Edit(./.env.ci)",
      "Edit(./.env.docker)",
      "Edit(./secrets/**)",
      "Edit(./config/credentials.json)",
      "Read(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Write(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Read(~/.kube/config)",
      "Write(~/.kube/config)",
      "Edit(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Write(~/.docker/config.json)",
      "Edit(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Write(~/.npmrc)",
      "Edit(~/.npmrc)",
      "Read(~/.pypirc)",
      "Write(~/.pypirc)",
      "Edit(~/.pypirc)",
      "Read(~/.netrc)",
      "Write(~/.netrc)",
      "Edit(~/.netrc)",
      "Read(./**/*.tfstate)",
      "Write(./**/*.tfstate)",
      "Edit(./**/*.tfstate)",
      "Read(./**/*.tfvars)",
      "Write(./**/*.tfvars)",
      "Edit(./**/*.tfvars)",
      "Read(./**/*-credentials.json)",
      "Write(./**/*-credentials.json)",
      "Edit(./**/*-credentials.json)",
      "Read(./**/*.pem)",
      "Write(./**/*.pem)",
      "Edit(./**/*.pem)",
      "Read(./**/*.key)",
      "Write(./**/*.key)",
      "Edit(./**/*.key)",
      "Read(./**/*id_rsa*)",
      "Write(./**/*id_rsa*)",
      "Edit(./**/*id_rsa*)",
      "Read(./**/*id_ed25519*)",
      "Write(./**/*id_ed25519*)",
      "Edit(./**/*id_ed25519*)",
      "Read(**/node_modules/**)"
    ]
  },
  "model": "opus[1m]",
  "includeGitInstructions": false,
  "autoUpdatesChannel": "stable",
  "showThinkingSummaries": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/dangerous-command-blocker.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/secret-scanner.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/conventional-commits.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/gh-token-guard.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/glab-token-guard.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/large-file-blocker.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/env-file-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/env-file-guard.sh"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/env-file-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/smart-formatter.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/change-tracker.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/deslop-checker.sh"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/smart-formatter.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/change-tracker.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/deslop-checker.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/smart-formatter.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/change-tracker.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/deslop-checker.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v osascript >/dev/null 2>&1; then osascript -e 'display notification \"Response complete\" with title \"Claude Code\"'; elif command -v notify-send >/dev/null 2>&1; then notify-send 'Claude Code' 'Response complete'; fi"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-webhook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/scripts/context-monitor.py"
  },
  "worktree": {
    "symlinkDirectories": ["node_modules"]
  },
  "outputStyle": "Explanatory",
  "language": "english",
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-docker"
      ]
    },
    "lighthouse": {
      "command": "npx",
      "args": [
        "-y",
        "lighthouse-mcp"
      ]
    },
    "ollama": {
      "command": "npx",
      "args": [
        "-y",
        "ollama-mcp-server"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/gufranco/Dropbox",
        "/Users/gufranco/Workspace",
        "/Users/gufranco/Docker",
        "/tmp"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "gitlab": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-gitlab"
      ],
      "env": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "${GITLAB_TOKEN}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5454/field_service"
      ]
    },
    "redis": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis",
        "redis://localhost:6379"
      ]
    },
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    },
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "obsidian-mcp-server"
      ],
      "env": {
        "OBSIDIAN_VAULT_PATH": "${OBSIDIAN_VAULT_PATH}"
      }
    },
    "kubernetes": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-kubernetes"
      ]
    },
    "aws": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-aws"
      ]
    },
    "cloudflare": {
      "command": "npx",
      "args": [
        "-y",
        "@cloudflare/mcp-server-cloudflare"
      ],
      "env": {
        "CLOUDFLARE_API_TOKEN": "${CLOUDFLARE_API_TOKEN}"
      }
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "google-maps": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-maps"
      ],
      "env": {
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
      }
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "resend": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-resend"
      ],
      "env": {
        "RESEND_API_KEY": "${RESEND_API_KEY}"
      }
    },
    "todoist": {
      "command": "npx",
      "args": [
        "-y",
        "todoist-mcp-server"
      ],
      "env": {
        "TODOIST_API_TOKEN": "${TODOIST_API_TOKEN}"
      }
    },
    "discord": {
      "command": "npx",
      "args": [
        "-y",
        "discord-mcp"
      ],
      "env": {
        "DISCORD_TOKEN": "${DISCORD_TOKEN}"
      }
    },
    "perplexity": {
      "command": "npx",
      "args": [
        "-y",
        "perplexity-mcp"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "langsmith": {
      "command": "npx",
      "args": [
        "-y",
        "langsmith-mcp-server"
      ],
      "env": {
        "LANGSMITH_API_KEY": "${LANGSMITH_API_KEY}"
      }
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp"
    },
    "linear": {
      "url": "https://mcp.linear.app/mcp"
    },
    "figma": {
      "url": "https://mcp.figma.com/mcp"
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp"
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "supabase": {
      "url": "https://mcp.supabase.com/mcp"
    },
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "mermaid-chart": {
      "url": "https://chatgpt.mermaid.ai/anthropic/mcp"
    },
    "excalidraw": {
      "url": "https://mcp.excalidraw.com/mcp"
    },
    "granola": {
      "url": "https://mcp.granola.ai/mcp"
    },
    "miro": {
      "url": "https://mcp.miro.com/"
    },
    "asana": {
      "url": "https://mcp.asana.com/v2/mcp"
    },
    "microsoft-learn": {
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "semgrep": {
      "command": "uvx",
      "args": [
        "semgrep-mcp"
      ]
    },
    "qdrant": {
      "command": "uvx",
      "args": [
        "mcp-server-qdrant"
      ],
      "env": {
        "QDRANT_URL": "http://localhost:6333",
        "COLLECTION_NAME": "code-search",
        "TOOL_STORE_DESCRIPTION": "Store code snippets, patterns, and architecture decisions for semantic retrieval",
        "TOOL_FIND_DESCRIPTION": "Search for code patterns, implementations, or architectural decisions by describing what you need in natural language"
      }
    }
  }
}
