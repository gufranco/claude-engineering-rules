{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/onyxodds/dot-claude/schemas/mutation-method-blocker-lsp.schema.json",
  "title": "Mutation Method Blocker LSP Output",
  "description": "Schema for the JSON array emitted when MUTATION_METHOD_OUTPUT=lsp. Mirrors LSP 3.17 PublishDiagnosticsParams, one entry per scanned file with findings.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/PublishDiagnosticsParams"
  },
  "$defs": {
    "PublishDiagnosticsParams": {
      "type": "object",
      "required": ["uri", "diagnostics"],
      "additionalProperties": false,
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri",
          "pattern": "^file:///",
          "description": "Absolute file:// URI of the scanned source file."
        },
        "version": {
          "type": ["integer", "null"],
          "description": "Document version, or null when the emitter does not track versions."
        },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/Diagnostic" }
        }
      }
    },
    "Diagnostic": {
      "type": "object",
      "required": ["range", "severity", "code", "source", "message"],
      "additionalProperties": false,
      "properties": {
        "range": { "$ref": "#/$defs/Range" },
        "severity": {
          "type": "integer",
          "enum": [1, 2, 3, 4],
          "description": "1=Error, 2=Warning, 3=Information, 4=Hint per LSP 3.17."
        },
        "code": {
          "type": "string",
          "pattern": "^MMB[0-9]{3}$",
          "description": "Stable mutation-method-blocker code."
        },
        "codeDescription": { "$ref": "#/$defs/CodeDescription" },
        "source": {
          "type": "string",
          "const": "mutation-method-blocker"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "data": { "$ref": "#/$defs/DiagnosticData" }
      }
    },
    "Range": {
      "type": "object",
      "required": ["start", "end"],
      "additionalProperties": false,
      "properties": {
        "start": { "$ref": "#/$defs/Position" },
        "end": { "$ref": "#/$defs/Position" }
      }
    },
    "Position": {
      "type": "object",
      "required": ["line", "character"],
      "additionalProperties": false,
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based line offset per LSP 3.17."
        },
        "character": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based character offset per LSP 3.17."
        }
      }
    },
    "CodeDescription": {
      "type": "object",
      "required": ["href"],
      "additionalProperties": false,
      "properties": {
        "href": {
          "type": "string",
          "format": "uri",
          "description": "URL to the rule's documentation."
        }
      }
    },
    "DiagnosticData": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "detector": {
          "type": "string",
          "description": "Internal detector identifier such as array.push or map.set."
        },
        "category": {
          "type": "string",
          "description": "Category prefix derived from the detector."
        },
        "snippet": {
          "type": "string",
          "description": "Original matched source text."
        },
        "version": {
          "type": "string",
          "description": "mutation-method-blocker version."
        },
        "lspVersion": {
          "type": "string",
          "description": "LSP protocol version this payload conforms to."
        }
      }
    }
  }
}
